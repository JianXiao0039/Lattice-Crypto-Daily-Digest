# Optional: contact email used by polite academic API requests when supported by the source.
CONTACT_EMAIL=

# Optional: Semantic Scholar API key for better rate-limit behavior.
SEMANTIC_SCHOLAR_API_KEY=

# Optional: local proxy settings used by local backfill scripts when .env is present.
HTTP_PROXY=
HTTPS_PROXY=

# Optional SMTP settings. Required only when email delivery is enabled.
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
DIGEST_EMAIL_FROM=
DIGEST_EMAIL_TO=

# Optional legacy aliases accepted by scripts/send_latest_digest_email.py.
SMTP_USER=
MAIL_FROM=
MAIL_TO=
