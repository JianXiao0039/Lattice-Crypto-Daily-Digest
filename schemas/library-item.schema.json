{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/lattice-crypto-daily-digest/schemas/library-item.schema.json",
  "title": "Lattice Crypto Library Item",
  "type": "object",
  "required": [
    "schema_version",
    "item_id",
    "dedup_key",
    "title",
    "authors",
    "source",
    "url",
    "research_tags",
    "zotero_tags",
    "export_warnings"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "item_id": { "type": "string" },
    "dedup_key": { "type": "string" },
    "title": { "type": "string" },
    "authors": { "type": "array", "items": { "type": "string" } },
    "year": { "type": ["integer", "string", "null"] },
    "date": { "type": "string" },
    "source": { "type": "string" },
    "source_type": { "type": "string" },
    "venue": { "type": "string" },
    "abstract": { "type": "string" },
    "url": { "type": "string" },
    "pdf_url": { "type": "string" },
    "doi": { "type": "string" },
    "arxiv_id": { "type": "string" },
    "eprint_id": { "type": "string" },
    "semantic_scholar_id": { "type": "string" },
    "openalex_id": { "type": "string" },
    "dblp_url": { "type": "string" },
    "crossref_doi": { "type": "string" },
    "normalized_identifiers": { "type": "object" },
    "source_trace": { "type": "array", "items": { "type": "string" } },
    "first_seen_date": { "type": "string" },
    "last_seen_date": { "type": "string" },
    "digest_dates": { "type": "array", "items": { "type": "string" } },
    "reading_priority_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "priority_label": { "type": "string" },
    "reason_for_priority": { "type": "string" },
    "why_it_matters": { "type": "string" },
    "suggested_action": { "type": "string" },
    "research_tags": { "type": "array", "items": { "type": "string" } },
    "lattice_tags": { "type": "array", "items": { "type": "string" } },
    "pqc_tags": { "type": "array", "items": { "type": "string" } },
    "ai_tags": { "type": "array", "items": { "type": "string" } },
    "attack_tags": { "type": "array", "items": { "type": "string" } },
    "primitive_tags": { "type": "array", "items": { "type": "string" } },
    "implementation_tags": { "type": "array", "items": { "type": "string" } },
    "zotero_tags": { "type": "array", "items": { "type": "string" } },
    "obsidian_links": { "type": "array", "items": { "type": "string" } },
    "obsidian_note_hint": { "type": "string" },
    "idea_hooks": { "type": "array", "items": { "type": "string" } },
    "advisor_questions": { "type": "array", "items": { "type": "string" } },
    "export_warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
